# ── Connected mode — proxy to the root admin panel instead of local Supabase ───
# "false" → Local mode (default): /api/auth/* and /api/admin/* read/write this
#           app's own Supabase (below) — unchanged existing behavior.
# "true"  → Connected mode: /api/auth/* and everything under /api/admin/*
#           (companies, users, tools, theme, blogs, and every generic
#           collection/singleton under /settings) proxy to the root admin
#           panel at NEXT_PUBLIC_ADMIN_API_URL instead. See lib/connect.js.
#
# IMPORTANT — connected mode requires JWT_SECRET and JWT_REFRESH_SECRET below
# to be set to the SAME values as the root app's. Login/refresh hand back
# root-issued tokens as-is, and this app's own /settings SSR gate
# (app/settings/layout.js, proxy.js) verifies them locally with its own
# secret — different secrets means those tokens fail local verification and
# every /settings page bounces back to login even though the token is valid.
NEXT_PUBLIC_IS_CONNECT=false
# Base URL of the root admin panel (arshanemi-admin-pannels), e.g.
# http://localhost:3000 or https://admin.yoursite.com. Required when
# NEXT_PUBLIC_IS_CONNECT=true.
NEXT_PUBLIC_ADMIN_API_URL=
# Server-only, long-lived master_admin Bearer token used for server-to-server
# admin CRUD proxying (companies/users/tools/blogs/theme/...) — NOT the
# visiting user's own session token. Mint once against the root app and paste
# here. Only needed when NEXT_PUBLIC_IS_CONNECT=true.
ADMIN_API_TOKEN=

# "true"  → Billing gate active (mirrors tools/arshanemi-tools-1's
#           NEXT_PUBLIC_IS_PAID) — reserved for a future per-feature billing
#           gate in this app. Independent of NEXT_PUBLIC_IS_CONNECT.
# "false" → No billing enforcement (default) — no call site wired up yet.
NEXT_PUBLIC_IS_PAID=false

# "true"  → OTP verification is bypassed everywhere (lib/db.js's verifyOTP()
#           accepts any code unconditionally) and every OTP step/input in the
#           UI is skipped — login (master_admin/otp_enabled users), change
#           password, change email/mobile, and forgot-password all become
#           single-step flows. Dev/staging convenience only — never enable in
#           production.
# "false" → OTP enforced everywhere as normal (default).
NEXT_PUBLIC_IS_OTP_Verifications_Disable=false

# ── UI flags ─────────────────────────────────────────────────────────────────
# "true" → hides the main DashboardTopbar header on / and /profile.
NEXT_PUBLIC_IS_Header_Hide=false
# "true" → shows a collapsible floating shortcuts menu (Home/Settings/Logout)
# pinned bottom-right on / and /profile.
NEXT_PUBLIC_IS_Bottom_Menu=false

# ── Local storage backend for the generic /settings collections/singletons ────
# (blogs, industries, testimonials, team, partners, case-studies, faqs,
# services, theme, navigation, hero, about, contact, company, ...) — the ones
# backed by lib/db.js's getCollection/getSingleton family. Does NOT affect the
# dedicated tables (users, companies, tools catalog, files-expiry) — those
# always use Supabase. See lib/blobStore.js.
# "false" → Database (default): read/write the layout_settings Supabase table.
# "true"  → JSON files in Vercel Blob instead — no database table touched.
#           Stored as database/<TOOLS_NAME slug>/<key>.json, e.g.
#           database/arshanemi-tools-dashboard/blogs.json. Reuses the
#           BLOB_STORE_ID / BLOB_READ_WRITE_TOKEN below.
NEXT_PUBLIC_IS_JSON_SAVED_DATA=false
# Namespaces this tool's JSON files within a shared Blob store so multiple
# tools don't collide. Only used when NEXT_PUBLIC_IS_JSON_SAVED_DATA=true.
TOOLS_NAME=arshanemi-tools-dashboard

# ── Supabase PostgreSQL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<your-supabase-publishable-key>"

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Access token secret (min 64 chars)
JWT_SECRET="<your-jwt-secret-min-64-chars>"
# Refresh token secret — use a different value from JWT_SECRET
JWT_REFRESH_SECRET="<your-jwt-refresh-secret-min-64-chars>"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── CORS — external static clients calling /api/* directly from the browser ────
# (e.g. tools/arshanemi-tools-dashboard's login.html / index.html). Comma-separated
# list of exact origins (scheme + host + port, no trailing slash, no path).
# Defaults to http://localhost:5500,http://127.0.0.1:5500 if unset.
ALLOWED_ORIGINS="http://localhost:5500,http://127.0.0.1:5500"

# ── SMTP — Gmail App Password ───────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="<your-sender-email>"
SMTP_PASS="<your-gmail-app-password>"
COMPANY_EMAIL_TO="<your-support-email>"

# ── MSG91 (SMS OTP delivery) — optional ─────────────────────────────────────────
# If unset, mobile OTPs are just logged to the console (dev fallback) — the
# OTP is always saved to the database either way. Template must be a
# DLT-approved SMS template with one variable for the OTP code.
MSG91_AUTH_KEY="<your-msg91-authkey>"
MSG91_TEMPLATE_ID="<your-msg91-template-id>"
# Variable name inside the template that receives the OTP code (default VAR1)
MSG91_OTP_VAR_NAME="VAR1"
# Country code prepended to bare 10-digit numbers (default 91)
MSG91_DEFAULT_COUNTRY_CODE="91"

# ── Vercel Blob (media uploads) ────────────────────────────────────────────────
BLOB_STORE_ID="<your-blob-store-id>"
BLOB_READ_WRITE_TOKEN="<your-blob-read-write-token>"