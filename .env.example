# ── Supabase PostgreSQL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<your-supabase-publishable-key>"

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Access token secret (min 64 chars)
JWT_SECRET="<your-jwt-secret-min-64-chars>"
# Refresh token secret — use a different value from JWT_SECRET
JWT_REFRESH_SECRET="<your-jwt-refresh-secret-min-64-chars>"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── CORS — external static clients calling /api/* directly from the browser ────
# (e.g. tools/arshanemi-tools-dashboard's login.html / index.html). Comma-separated
# list of exact origins (scheme + host + port, no trailing slash, no path).
# Defaults to http://localhost:5500,http://127.0.0.1:5500 if unset.
ALLOWED_ORIGINS="http://localhost:5500,http://127.0.0.1:5500"

# ── SMTP — Gmail App Password ───────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="<your-sender-email>"
SMTP_PASS="<your-gmail-app-password>"
COMPANY_EMAIL_TO="<your-support-email>"

# ── MSG91 (SMS OTP delivery) — optional ─────────────────────────────────────────
# If unset, mobile OTPs are just logged to the console (dev fallback) — the
# OTP is always saved to the database either way. Template must be a
# DLT-approved SMS template with one variable for the OTP code.
MSG91_AUTH_KEY="<your-msg91-authkey>"
MSG91_TEMPLATE_ID="<your-msg91-template-id>"
# Variable name inside the template that receives the OTP code (default VAR1)
MSG91_OTP_VAR_NAME="VAR1"
# Country code prepended to bare 10-digit numbers (default 91)
MSG91_DEFAULT_COUNTRY_CODE="91"

# ── Vercel Blob (media uploads) ────────────────────────────────────────────────
BLOB_STORE_ID="<your-blob-store-id>"
BLOB_READ_WRITE_TOKEN="<your-blob-read-write-token>"